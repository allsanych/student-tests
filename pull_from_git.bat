@echo off
color 0B
echo ===================================================
echo     ОНОВЛЕННЯ ЛОКАЛЬНИХ ФАЙЛІВ З GITHUB
echo ===================================================
echo.
echo Перевірка наявності оновлень в інтернеті...
echo.

git fetch origin main

echo.
echo Завантаження та об'єднання змін...
echo.

git pull origin main

if %ERRORLEVEL% NEQ 0 (
    echo.
    echo [УВАГА] Виникла помилка при синхронізації.
    echo Можливо, у вас є незбережені локальні зміни, які конфліктують з онлайн-версією.
    echo Спробуйте спочатку запустити push_to_git.bat, щоб зберегти свої зміни.
) else (
    echo.
    echo ===================================================
    echo     СИНХРОНІЗАЦІЮ ЗАВЕРШЕНО УСПІШНО!
    echo ===================================================
    echo Ваші локальні файли тепер відповідають версії на GitHub.
)

echo.
pause
